<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Frostfall — Staff</title>
  <link rel="icon" href="/assets/logo-static.jpg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Cormorant+SC:wght@400;500;600;700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="/dashboard.css">
</head>
<body>

<% if (!user) { %>

<!-- ════════════════════════════════════════════════════════════════════════════
     LOGIN GATE
     ════════════════════════════════════════════════════════════════════════════ -->
<div class="dash-gate">
  <div class="dash-gate-card">
    <a href="/" class="dash-gate-seal">
      <img src="/assets/logo-animated.gif" alt="Frostfall seal">
    </a>
    <div class="eyebrow metallic">staff access</div>
    <div class="rule dash-gate-rule"><span class="rule-glyph metallic">✦</span></div>
    <h1 class="dash-gate-title">Frostfall</h1>
    <p class="dash-gate-sub">Sign in with Discord to continue.</p>
    <a href="/auth/dashboard/login" class="btn-discord">
      <svg class="discord-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
      </svg>
      Sign in with Discord
    </a>
    <% if (authError) { %>
      <p class="dash-gate-error"><%= authError %></p>
    <% } %>
  </div>
</div>

<% } else { %>

<!-- ════════════════════════════════════════════════════════════════════════════
     DASHBOARD
     ════════════════════════════════════════════════════════════════════════════ -->
<%
  let roleLabel = ''
  if (permissions.includes('admin.*'))                   roleLabel = 'Management'
  else if (permissions.includes('lore.write'))            roleLabel = 'Lore Master'
  else if (permissions.includes('staff.whitelist_info'))  roleLabel = 'Support Staff'
%>

<div class="dash-layout">

  <!-- ── Sidebar ──────────────────────────────────────────────────────────── -->
  <aside class="dash-sidebar">

    <div class="dash-sidebar-brand">
      <a href="/" class="dash-sidebar-logo">
        <img src="/assets/logo-animated.gif" alt="">
        <span>Frostfall</span>
      </a>
    </div>

    <div class="dash-sidebar-user">
      <% if (user.avatar) { %>
        <img class="dash-avatar" src="<%= user.avatar %>" alt="">
      <% } %>
      <div class="dash-sidebar-user-info">
        <span class="dash-username"><%= user.username %></span>
        <span class="dash-sidebar-role"><%= roleLabel %></span>
      </div>
    </div>

    <div class="dash-sidebar-divider"></div>

    <nav class="dash-sidebar-nav" role="navigation" aria-label="Dashboard sections">

      <% if (canServer) { %>
      <button class="dash-nav-item" data-view="server" role="menuitem">
        <svg class="dash-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="3" width="20" height="6" rx="1"/>
          <rect x="2" y="14" width="20" height="6" rx="1"/>
          <circle cx="6" cy="6" r="1" fill="currentColor" stroke="none"/>
          <circle cx="6" cy="17" r="1" fill="currentColor" stroke="none"/>
        </svg>
        Server
        <span class="dash-nav-status" id="nav-status-dot"></span>
      </button>
      <% } %>

      <% if (canLore) { %>
      <button class="dash-nav-item" data-view="lore" role="menuitem">
        <svg class="dash-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
        Lore
      </button>
      <% } %>

      <% if (canRules) { %>
      <button class="dash-nav-item" data-view="rules" role="menuitem">
        <svg class="dash-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="8" y1="6"  x2="21" y2="6"/>
          <line x1="8" y1="12" x2="21" y2="12"/>
          <line x1="8" y1="18" x2="21" y2="18"/>
          <line x1="3" y1="6"  x2="3.01" y2="6"/>
          <line x1="3" y1="12" x2="3.01" y2="12"/>
          <line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
        Rules
      </button>
      <% } %>

      <% if (canWhitelist) { %>
      <button class="dash-nav-item" data-view="whitelist" role="menuitem">
        <svg class="dash-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="m16 11 2 2 4-4"/>
        </svg>
        Whitelist
      </button>
      <% } %>

    </nav>

    <div class="dash-sidebar-footer">
      <a href="/" class="dash-sidebar-footer-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="14" height="14">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        Back to site
      </a>
      <form method="POST" action="/auth/dashboard/logout" style="display:contents">
        <button type="submit" class="dash-sidebar-footer-link dash-sidebar-signout">Sign out</button>
      </form>
    </div>

  </aside>

  <!-- ── Main content ──────────────────────────────────────────────────────── -->
  <main class="dash-main">

    <!-- ── View: Server (Management only) ─────────────────────────────────── -->
    <% if (canServer) { %>
    <div id="view-server" class="dash-view hidden">

      <div class="dash-view-header">
        <div class="eyebrow metallic">management</div>
        <h1 class="dash-view-title">Server Dashboard</h1>
      </div>

      <div class="dash-inner-tabs" role="tablist">
        <button class="dash-inner-tab is-active" role="tab" data-inner="control" aria-selected="true">Control</button>
        <button class="dash-inner-tab" role="tab" data-inner="logs"    aria-selected="false">Logs</button>
        <button class="dash-inner-tab" role="tab" data-inner="files"   aria-selected="false">Files</button>
      </div>

      <!-- Control -->
      <div id="inner-control" class="dash-inner-panel">
        <section class="dash-section-card">
          <div class="dash-section-head">
            <div>
              <div class="eyebrow metallic">game server</div>
              <h2 class="dash-section-title">Control</h2>
            </div>
          </div>
          <div class="dash-status-block">
            <div class="dash-status-ring" id="status-ring">
              <span class="dash-status-dot-lg" id="status-dot-lg"></span>
            </div>
            <div class="dash-status-text">
              <span class="dash-status-state" id="status-label">Checking…</span>
              <span class="dash-status-meta"  id="server-meta"></span>
            </div>
          </div>
          <div class="dash-action-row">
            <button class="dash-btn dash-btn-primary" id="btn-start"   onclick="serverAction('start')">Start</button>
            <button class="dash-btn dash-btn-ghost"   id="btn-restart" onclick="serverAction('restart')">Restart</button>
            <button class="dash-btn dash-btn-danger"  id="btn-stop"    onclick="serverAction('stop')">Stop</button>
          </div>
        </section>
      </div>

      <!-- Logs -->
      <div id="inner-logs" class="dash-inner-panel hidden">
        <section class="dash-section-card dash-section-card--logs">
          <div class="dash-section-head">
            <div>
              <div class="eyebrow metallic">output stream</div>
              <h2 class="dash-section-title">Server Logs</h2>
            </div>
            <div class="dash-log-controls">
              <label class="dash-toggle">
                <input type="checkbox" id="log-follow" checked>
                <span>Follow</span>
              </label>
              <button class="dash-btn dash-btn-ghost dash-btn-sm" onclick="refreshLogs()">Refresh</button>
            </div>
          </div>
          <pre class="dash-log-output" id="log-output"><span class="log-faint">Loading…</span></pre>
        </section>
      </div>

      <!-- Files -->
      <div id="inner-files" class="dash-inner-panel hidden">
        <section class="dash-section-card">
          <div class="dash-section-head">
            <div>
              <div class="eyebrow metallic">filesystem</div>
              <h2 class="dash-section-title">File Manager</h2>
            </div>
            <label class="dash-btn dash-btn-ghost dash-btn-sm dash-upload-label">
              Upload
              <input type="file" id="upload-input" multiple hidden>
            </label>
          </div>
          <nav class="dash-breadcrumb" id="breadcrumb" aria-label="Path"></nav>
          <div class="dash-file-list" id="file-list">
            <div class="dash-file-empty">Loading…</div>
          </div>
        </section>
      </div>

    </div><!-- /view-server -->
    <% } %>

    <!-- ── View: Lore ────────────────────────────────────────────────────── -->
    <% if (canLore) { %>
    <div id="view-lore" class="dash-view hidden">

      <div class="dash-view-header">
        <div class="eyebrow metallic">lore council</div>
        <h1 class="dash-view-title">Lore Wiki</h1>
        <button class="dash-btn dash-btn-primary dash-btn-sm" onclick="loreNewEntry()">+ New Entry</button>
      </div>

      <div id="dash-lore-list" class="dash-content-list">
        <div class="dash-file-empty">Loading…</div>
      </div>

    </div><!-- /view-lore -->
    <% } %>

    <!-- ── View: Rules ───────────────────────────────────────────────────── -->
    <% if (canRules) { %>
    <div id="view-rules" class="dash-view hidden">

      <div class="dash-view-header">
        <div class="eyebrow metallic">rp &amp; conduct</div>
        <h1 class="dash-view-title">Rules</h1>
        <button class="dash-btn dash-btn-primary dash-btn-sm" onclick="rulesNewEntry()">+ New Rule</button>
      </div>

      <div id="dash-rules-list" class="dash-content-list">
        <div class="dash-file-empty">Loading…</div>
      </div>

    </div><!-- /view-rules -->
    <% } %>

    <% if (canWhitelist) { %>
    <div id="view-whitelist" class="dash-view hidden">

      <div class="dash-view-header">
        <div class="eyebrow metallic">access roster</div>
        <h1 class="dash-view-title">Whitelist</h1>
        <button class="dash-btn dash-btn-ghost dash-btn-sm" onclick="loadWhitelistView()">Refresh</button>
      </div>

      <section class="dash-section-card">
        <div class="dash-section-head">
          <div>
            <div class="eyebrow metallic">discord role</div>
            <h2 class="dash-section-title">Whitelisted Players</h2>
          </div>
          <span class="dash-section-meta" id="dash-whitelist-count">Loading...</span>
        </div>
        <div id="dash-whitelist-list" class="dash-content-list dash-content-list--flush">
          <div class="dash-file-empty">Loading...</div>
        </div>
      </section>

      <section class="dash-section-card">
        <div class="dash-section-head">
          <div>
            <div class="eyebrow metallic">staff reference</div>
            <h2 class="dash-section-title">Whitelist Handling Notes</h2>
          </div>
          <% if (canWhitelistWrite) { %>
          <button class="dash-btn dash-btn-ghost dash-btn-sm" onclick="rulesEditNotes()">Edit Notes</button>
          <% } %>
        </div>
        <pre class="dash-log-output" id="dash-notes-content" style="min-height:6rem;white-space:pre-wrap">Loading...</pre>
      </section>

    </div><!-- /view-whitelist -->
    <% } %>

  </main>
</div><!-- /dash-layout -->

<!-- ════════════════════════════════════════════════════════════════════════════
     MODALS  (only rendered for users with the matching permission)
     ════════════════════════════════════════════════════════════════════════════ -->

<!-- Lore entry editor -->
<% if (canLore) { %>
<div class="dash-backdrop hidden" id="lore-entry-backdrop">
  <div class="dash-modal dash-modal--wide">
    <header class="dash-modal-head">
      <span class="dash-modal-path" id="lore-entry-modal-title">Lore Entry</span>
      <button class="dash-modal-close" onclick="closeLoreEntryModal()" aria-label="Close">✕</button>
    </header>
    <div class="dash-modal-body">
      <div class="dash-form-field">
        <label class="dash-form-label" for="lore-entry-title">Title</label>
        <input class="dash-form-input" type="text" id="lore-entry-title" placeholder="e.g. The White-Gold Concordat" autocomplete="off">
      </div>
      <div class="dash-form-field">
        <label class="dash-form-label" for="lore-entry-category">Category</label>
        <input class="dash-form-input" type="text" id="lore-entry-category" placeholder="e.g. politics, factions, holds" autocomplete="off">
      </div>
      <div class="dash-form-field">
        <label class="dash-form-label">Content</label>
        <div id="lore-editor-mount"></div>
      </div>
    </div>
    <footer class="dash-modal-foot">
      <button class="dash-btn dash-btn-ghost   dash-btn-sm" onclick="closeLoreEntryModal()">Cancel</button>
      <button class="dash-btn dash-btn-primary dash-btn-sm" id="lore-save-btn" onclick="saveLoreEntry()">Save</button>
    </footer>
  </div>
</div>
<% } %>

<!-- Rule editor -->
<% if (canRules) { %>
<div class="dash-backdrop hidden" id="rule-entry-backdrop">
  <div class="dash-modal dash-modal--wide">
    <header class="dash-modal-head">
      <span class="dash-modal-path" id="rule-entry-modal-title">Rule</span>
      <button class="dash-modal-close" onclick="closeRuleEntryModal()" aria-label="Close">✕</button>
    </header>
    <div class="dash-modal-body">
      <div class="dash-form-field">
        <label class="dash-form-label" for="rule-entry-title">Title</label>
        <input class="dash-form-input" type="text" id="rule-entry-title" placeholder="e.g. Respect all players" autocomplete="off">
      </div>
      <div class="dash-form-field">
        <label class="dash-form-label">Content</label>
        <div id="rule-editor-mount"></div>
      </div>
    </div>
    <footer class="dash-modal-foot">
      <button class="dash-btn dash-btn-ghost   dash-btn-sm" onclick="closeRuleEntryModal()">Cancel</button>
      <button class="dash-btn dash-btn-primary dash-btn-sm" id="rule-save-btn" onclick="saveRuleEntry()">Save</button>
    </footer>
  </div>
</div>
<% } %>

<!-- Staff notes editor -->
<% if (canWhitelistWrite) { %>
<div class="dash-backdrop hidden" id="notes-entry-backdrop">
  <div class="dash-modal dash-modal--wide">
    <header class="dash-modal-head">
      <span class="dash-modal-path">Whitelist Handling Notes</span>
      <button class="dash-modal-close" onclick="closeNotesEntryModal()" aria-label="Close">✕</button>
    </header>
    <div class="dash-modal-body">
      <div class="dash-form-field">
        <label class="dash-form-label">Notes</label>
        <div id="notes-editor-mount"></div>
      </div>
    </div>
    <footer class="dash-modal-foot">
      <button class="dash-btn dash-btn-ghost   dash-btn-sm" onclick="closeNotesEntryModal()">Cancel</button>
      <button class="dash-btn dash-btn-primary dash-btn-sm" id="notes-save-btn" onclick="saveNotesEntry()">Save</button>
    </footer>
  </div>
</div>
<% } %>

<!-- Raw file editor (Management only) -->
<% if (canServer) { %>
<div class="dash-backdrop hidden" id="editor-backdrop">
  <div class="dash-modal">
    <header class="dash-modal-head">
      <span class="dash-modal-path" id="editor-title"></span>
      <button class="dash-modal-close" onclick="closeEditor()" aria-label="Close">✕</button>
    </header>
    <textarea class="dash-editor" id="editor-area" spellcheck="false"></textarea>
    <footer class="dash-modal-foot">
      <button class="dash-btn dash-btn-ghost   dash-btn-sm" onclick="closeEditor()">Cancel</button>
      <button class="dash-btn dash-btn-primary dash-btn-sm" onclick="saveFile()">Save</button>
    </footer>
  </div>
</div>
<% } %>

<script>
  window.__BACKEND_URL__ = <%- JSON.stringify(backendUrl) %>;
  window.__DASH_TOKEN__  = <%- JSON.stringify(dashToken)  %>;
</script>
<script src="https://cdn.jsdelivr.net/npm/marked@9/marked.min.js"></script>
<script src="/dashboard.js"></script>

<% } /* end if (user) */ %>

</body>
</html>
