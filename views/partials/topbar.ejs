<header class="topbar">
  <div class="container topbar-inner">
    <a href="/" class="brand-mark" aria-label="Frostfall home">
      <img class="brand-mark-seal" src="/assets/logo-animated.gif" alt="" aria-hidden="true" />
      <span>Frostfall</span>
    </a>
    <nav aria-label="Primary">
      <ul class="nav-links">
        <li><a href="/" <%- locals.page === 'home'      ? 'aria-current="page"' : '' %>>Home</a></li>
        <li><a href="/lore" <%- locals.page === 'lore'  ? 'aria-current="page"' : '' %>>Lore</a></li>
        <li><a href="/rules" <%- locals.page === 'rules' ? 'aria-current="page"' : '' %>>Rules</a></li>
        <li><a href="/dashboard" <%- locals.page === 'dashboard' ? 'aria-current="page"' : '' %>>Dashboard</a></li>
        <li>
          <a class="nav-link-accent" href="https://discord.gg/4KHMqUUKNT" target="_blank" rel="noopener">Discord</a>
        </li>
      </ul>
    </nav>
    <button class="theme-toggle" data-theme-toggle aria-label="Switch to light mode" type="button">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
      </svg>
    </button>
  </div>
</header>
